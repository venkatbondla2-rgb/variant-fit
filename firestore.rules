rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Posts Collection (Feed)
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated(); // Allow likes increments
      allow delete: if isOwner(resource.data.userId);
      
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }
    }

    // 2. Workouts Collection (Track)
    match /workouts/{workoutId} {
      // Users can only read, create, update, and delete their OWN workouts
      allow read, create, update, delete: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isOwner(resource.data.userId); 
    }

    // 3. Diet Logs Collection
    match /diet_logs/{logId} {
      // Users can only read, create, update, and delete their OWN diet logs
      allow read, create, update, delete: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isOwner(resource.data.userId); 
    }

    // 4. Questions Collection (Help)
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isOwner(resource.data.userId);

      match /replies/{replyId} {
        allow read: if isAuthenticated();
        // Allow creating if authenticated and setting self as author
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    // 4. Communities Collection (Groups)
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      // Anyone logged in can create a community
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      // Only members or owners can update (simplified for now)
      allow update: if isAuthenticated();
      allow delete: if isOwner(resource.data.ownerId);
    }

    // 5. Chats and Messages (Messenger)
    match /chats/{chatId} {
      // Users can only read/create chats if their UID is in the participants array
      allow read, create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        // Users can read and write messages only if they are part of the parent chat
        allow read, create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }
    // 6. Users Collection (Profile)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // 7. Notifications Collection
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Anyone can create a notification (e.g. liking, commenting on someone else's post)
      allow create: if isAuthenticated();
      // Only the owner can update (to mark as read) or delete
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    // 8. Training Sessions Collection
    match /training_sessions/{sessionId} {
      allow read, update: if isAuthenticated() && (resource.data.hostId == request.auth.uid || resource.data.guestId == request.auth.uid || request.resource.data.hostId == request.auth.uid || request.resource.data.guestId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.hostId == request.auth.uid || resource.data.guestId == request.auth.uid);
    }

    // 9. Admin managed collections
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      // Allow any auth user to create/update mock items for testing
      allow write: if isAuthenticated(); 
    }
    
    match /ads/{adId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
